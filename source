local function updateScale()
	local vp = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080);
	local mobile = isMobile();
	if mobile then
		local shortSide = math.min(vp.X, vp.Y);
		local ratio = shortSide / 600;
		local scale = math.clamp(ratio, 0.38, 0.7);
		scale *= 1.1;
		uiScale.Scale = math.clamp(scale, 0.4, 0.78);
	else
		local ratio = math.min(vp.X / 1050, vp.Y / 620);
		uiScale.Scale = math.clamp(ratio, 0.85, 1.4);
	end;
end;
