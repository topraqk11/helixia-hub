					panel.Visible = false;
				end;
			end);
		end;
	end);
	header.MouseEnter:Connect(function()
		Util.Tween(card, {
			BackgroundColor3 = theme.Palette.Elevated
		}, 0.13);
	end);
	header.MouseLeave:Connect(function()
		Util.Tween(card, {
			BackgroundColor3 = theme.Palette.Surface
		}, 0.13);
	end);
	function api:SetValue(c, a)
		h, s, v = Color3.toHSV(c);
		if a ~= nil then
			alpha = math.clamp(a, 0, 1);
		end;
		svCursor.Position = UDim2.new(s, 0, 1 - v, 0);
		hueCursor.Position = UDim2.new(h, 0, 0.5, 0);
		alphaCursor.Position = UDim2.new(alpha, 0, 0.5, 0);
		svSquare.BackgroundColor3 = Color3.fromHSV(h, 1, 1);
		applyColor();
	end;
	api.Instance = card;
	theme:Register(function(t)
		card.BackgroundColor3 = t.Palette.Surface;
		lbl.TextColor3 = t.Palette.Text;
		hexBox.BackgroundColor3 = t.Palette.SurfaceAlt;
		hexBox.TextColor3 = t.Palette.Text;
		alphaBox.BackgroundColor3 = t.Palette.SurfaceAlt;
		alphaBox.TextColor3 = t.Palette.Text;
	end);
	return api;
end;
function TabMethods:CreateInput(config)
	config = config or {};
	local theme = self.Window.Theme;
	local tabData = self;
	local card = baseCard(tabData.Page, theme, 50);
	card.LayoutOrder = nextOrder(tabData);
	local label = Instance.new("TextLabel");
	label.BackgroundTransparency = 1;
	label.Text = config.Text or "Input";
	label.Font = theme.Font;
	label.TextSize = 13;
	label.TextColor3 = theme.Palette.Text;
	label.TextXAlignment = Enum.TextXAlignment.Left;
	label.Position = UDim2.new(0, 15, 0, 0);
	label.Size = UDim2.new(0.38, 0, 1, 0);
	label.Parent = card;
	local box = Instance.new("Frame");
	box.BackgroundColor3 = theme.Palette.SurfaceAlt;
	box.BackgroundTransparency = 0.2;
	box.Size = UDim2.new(0.56, 0, 0, 30);
	box.Position = UDim2.new(1, -15, 0.5, 0);
	box.AnchorPoint = Vector2.new(1, 0.5);
	box.Parent = card;
	Util.Corner(box, 7);
	local stroke = Util.Stroke(box, theme.Palette.Accent, 1, 1);
	local input = Instance.new("TextBox");
	input.BackgroundTransparency = 1;
	input.PlaceholderText = config.Placeholder or "";
	input.Text = config.Default or "";
	input.Font = theme.Font;
	input.TextSize = 12;
	input.TextColor3 = theme.Palette.Text;
	input.PlaceholderColor3 = theme.Palette.TextFaint;
	input.ClearTextOnFocus = false;
	input.Size = UDim2.new(1, -14, 1, 0);
	input.Position = UDim2.new(0, 7, 0, 0);
	input.MaxVisibleGraphemes = config.MaxLength or (-1);
	input.Parent = box;
	if config.CharLimit then
		local charCount = Instance.new("TextLabel");
		charCount.BackgroundTransparency = 1;
		charCount.Text = "0/" .. config.CharLimit;
		charCount.Font = theme.Font;
		charCount.TextSize = 10;
		charCount.TextColor3 = theme.Palette.TextFaint;
		charCount.Position = UDim2.new(1, -54, 1, 2);
		charCount.Size = UDim2.fromOffset(50, 12);
		charCount.TextXAlignment = Enum.TextXAlignment.Right;
		charCount.Parent = card;
		(input:GetPropertyChangedSignal("Text")):Connect(function()
			local len = utf8.len(input.Text) or (#input.Text);
			if len > config.CharLimit then
				input.Text = input.Text:sub(1, config.CharLimit);
				len = config.CharLimit;
			end;
			charCount.Text = len .. "/" .. config.CharLimit;
			charCount.TextColor3 = len >= config.CharLimit and theme.Palette.Danger or theme.Palette.TextFaint;
		end);
		theme:Register(function(t)
			charCount.TextColor3 = t.Palette.TextFaint;
		end);
	end;
	local api = {
		Value = input.Text,
		Changed = Signal.new()
	};
	input.Focused:Connect(function()
		Util.Tween(stroke, {
			Transparency = 0.25
		}, 0.15);
		Util.Tween(box, {
			BackgroundColor3 = theme.Palette.Elevated
		}, 0.15);
	end);
	input.FocusLost:Connect(function(enterPressed)
		Util.Tween(stroke, {
			Transparency = 1
		}, 0.15);
		Util.Tween(box, {
			BackgroundColor3 = theme.Palette.SurfaceAlt
		}, 0.15);
		if config.Validate then
			local valid = config.Validate(input.Text);
			if not valid then
				Util.Tween(stroke, {
					Color = theme.Palette.Danger,
					Transparency = 0.25
				}, 0.13);
				task.delay(0.7, function()
					Util.Tween(stroke, {
						Color = theme.Palette.Accent,
						Transparency = 1
					}, 0.22);
				end);
				return;
			end;
		end;
		api.Value = input.Text;
		if config.Callback then
			task.spawn(config.Callback, input.Text, enterPressed);
		end;
		api.Changed:Fire(input.Text);
	end);
	function api:SetValue(v_)
		input.Text = v_;
	end;
	api.Instance = card;
	theme:Register(function(t)
		label.TextColor3 = t.Palette.Text;
		card.BackgroundColor3 = t.Palette.Surface;
		box.BackgroundColor3 = t.Palette.SurfaceAlt;
		input.TextColor3 = t.Palette.Text;
		input.PlaceholderColor3 = t.Palette.TextFaint;
		stroke.Color = t.Palette.Accent;
	end);
	return api;
end;
