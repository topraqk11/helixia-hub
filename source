function Window:_setZIndex(z)
	self.Root.ZIndex = z;
end;
function Window:_setFocused(focused)
	self.Focused = focused;
	Util.Tween(self.Root, {
		BackgroundTransparency = focused and self.Theme.Transparency or self.Theme.Transparency + 0.16
	}, 0.22);
end;
function Window:_filterTabs(query)
	query = query:lower();
	for _, tab in ipairs(self.Tabs) do
		local match = query == "" or (tab.Name:lower()):find(query, 1, true) ~= nil;
		tab.Button.Visible = match;
	end;
end;
function Window:Minimize()
	if self.Destroyed or self.Minimized then
		return;
	end;
	self.Minimized = true;
	adjustGlobalBlur(self.Theme, -1);
	local root = self.Root;
	self.PreMinimizeSize = root.Size;
	self.PreMinimizePosition = root.Position;
	local shrinkTween = Util.Tween(root, {
		Size = UDim2.fromOffset(root.Size.X.Offset * 0.82, root.Size.Y.Offset * 0.82),
		BackgroundTransparency = 1
	}, 0.28, Enum.EasingStyle.Quint);
	shrinkTween.Completed:Connect(function()
		if self.Minimized then
			root.Visible = false;
		end;
	end);
	local toggle = createFloatingToggle(self, self.Theme);
	toggle.Visible = true;
	toggle.Size = UDim2.fromScale(0.045, 0.045);
	toggle.BackgroundTransparency = 1;
	Util.Tween(toggle, {
		Size = UDim2.fromScale(0.07, 0.07),
		BackgroundTransparency = 0.05
	}, 0.3, Enum.EasingStyle.Back);
end;
function Window:Restore()
	if self.Destroyed or (not self.Minimized) then
		return;
	end;
	self.Minimized = false;
	adjustGlobalBlur(self.Theme, 1);
	local root = self.Root;
	root.Visible = true;
	root.Size = UDim2.fromOffset(self.PreMinimizeSize.X.Offset * 0.82, self.PreMinimizeSize.Y.Offset * 0.82);
	root.Position = self.PreMinimizePosition;
	root.BackgroundTransparency = 1;
	Util.Tween(root, {
		Size = self.PreMinimizeSize,
		BackgroundTransparency = self.Theme.Transparency
