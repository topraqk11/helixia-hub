			applyValue(stepped, true);
			valueBox.Text = formatVal(stepped);
		else
			valueBox.Text = formatVal(api.Value);
		end;
	end);
	function api:SetValue(v)
		local stepped = math.clamp(math.floor((v / increment + 0.5)) * increment, min, max);
		applyValue(stepped);
	end;
	api.Instance = card;
	theme:Register(function(t)
		fill.BackgroundColor3 = t.Palette.Accent;
		track.BackgroundColor3 = t.Palette.SurfaceAlt;
		valueBox.TextColor3 = t.Palette.Accent;
		valueBox.BackgroundColor3 = t.Palette.SurfaceAlt;
		card.BackgroundColor3 = t.Palette.Surface;
		label.TextColor3 = t.Palette.Text;
	end);
	return api;
end;
