		bodyLbl.TextWrapped = true;
		bodyLbl.TextXAlignment = Enum.TextXAlignment.Left;
		bodyLbl.Size = UDim2.new(1, 0, 0, 0);
		bodyLbl.AutomaticSize = Enum.AutomaticSize.Y;
		bodyLbl.Position = UDim2.new(0, 0, 0, 22);
		bodyLbl.Parent = inner;
	end;
	local progress = Instance.new("Frame");
	progress.BackgroundColor3 = accent;
	progress.BackgroundTransparency = 0.2;
	progress.Size = UDim2.new(1, 0, 0, 3);
	progress.AnchorPoint = Vector2.new(0, 1);
	progress.Position = UDim2.new(0, 0, 1, -1);
	progress.BorderSizePixel = 0;
	progress.Parent = card;
	card.Position = UDim2.new(0, 70, 0, 0);
	card.BackgroundTransparency = 1;
	Util.Tween(card, {
		Position = UDim2.new(0, 0, 0, 0),
		BackgroundTransparency = 0.04
	}, 0.32, Enum.EasingStyle.Back);
	local duration = config.Duration or 4;
	Util.Tween(progress, {
		Size = UDim2.new(0, 0, 0, 3)
	}, duration, Enum.EasingStyle.Linear);
	local function dismiss()
		local t = Util.Tween(card, {
			Position = UDim2.new(0, 70, 0, 0),
			BackgroundTransparency = 1
		}, 0.24, Enum.EasingStyle.Quad);
		t.Completed:Connect(function()
			card:Destroy();
		end);
	end;
	local clickArea = Instance.new("TextButton");
	clickArea.BackgroundTransparency = 1;
	clickArea.Text = "";
	clickArea.Size = UDim2.fromScale(1, 1);
	clickArea.ZIndex = card.ZIndex + 5;
	clickArea.Parent = card;
	clickArea.MouseButton1Click:Connect(dismiss);
