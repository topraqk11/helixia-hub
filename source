local ConfigManager = {};
ConfigManager.Store = {};
function ConfigManager:Bind(key, component)
	component.Changed:Connect(function(v_)
		self.Store[key] = v_;
	end);
	self.Store[key] = component.Value;
end;
function ConfigManager:Export()
	return HttpService:JSONEncode(self.Store);
end;
function ConfigManager:Import(jsonString, applyFn)
	local ok, decoded = pcall(HttpService.JSONDecode, HttpService, jsonString);
	if ok then
		self.Store = decoded;
		if applyFn then
			applyFn(decoded);
		end;
	end;
	return ok;
end;
function ConfigManager:Save(filename)
	if writefile then
		pcall(writefile, (filename or "HelixiaLIBConfig") .. ".json", self:Export());
	end;
end;
function ConfigManager:Load(filename, applyFn)
	if readfile and isfile and isfile((filename or "HelixiaLIBConfig") .. ".json") then
		return self:Import(readfile((filename or "HelixiaLIBConfig") .. ".json"), applyFn);
	end;
	return false;
end;
HelixiaLIB.Config = ConfigManager;

return HelixiaLIB;
