		if draggingSV then
			s = math.clamp((pos.X - svSquare.AbsolutePosition.X) / svSquare.AbsoluteSize.X, 0, 1);
			v = 1 - math.clamp((pos.Y - svSquare.AbsolutePosition.Y) / svSquare.AbsoluteSize.Y, 0, 1);
			svCursor.Position = UDim2.new(s, 0, 1 - v, 0);
			applyColor();
		elseif draggingHue then
			h = math.clamp((pos.X - hueStrip.AbsolutePosition.X) / hueStrip.AbsoluteSize.X, 0, 1);
			hueCursor.Position = UDim2.new(h, 0, 0.5, 0);
			applyColor();
		elseif draggingAlpha then
			alpha = math.clamp((pos.X - alphaStrip.AbsolutePosition.X) / alphaStrip.AbsoluteSize.X, 0, 1);
			alphaCursor.Position = UDim2.new(alpha, 0, 0.5, 0);
			applyColor();
		end;
	end);
	hexBox.FocusLost:Connect(function()
