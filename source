	card.Parent = notifyContainer;
	Util.Corner(card, theme.CornerRadius + 2);
	Util.Stroke(card, theme.Palette.Border, 1, 0.8);
	local bar = Instance.new("Frame");
	bar.BackgroundColor3 = accent;
	bar.Size = UDim2.new(0, 4, 1, 0);
	bar.BorderSizePixel = 0;
	bar.Parent = card;
	Util.Corner(bar, 4);
	local inner = Instance.new("Frame");
	inner.BackgroundTransparency = 1;
	inner.Position = UDim2.new(0, 18, 0, 0);
	inner.Size = UDim2.new(1, -18, 0, 0);
	inner.AutomaticSize = Enum.AutomaticSize.Y;
	inner.Parent = card;
	Util.Padding(inner, 14, 16, 0, 12);
	local titleLbl = Instance.new("TextLabel");
	titleLbl.BackgroundTransparency = 1;
	titleLbl.Text = config.Title or "Notification";
	titleLbl.Font = theme.FontBold;
	titleLbl.TextSize = 14;
	titleLbl.TextColor3 = theme.Palette.Text;
	titleLbl.TextXAlignment = Enum.TextXAlignment.Left;
	titleLbl.Size = UDim2.new(1, 0, 0, 18);
	titleLbl.Parent = inner;
	if config.Message and config.Message ~= "" then
		local bodyLbl = Instance.new("TextLabel");
		bodyLbl.BackgroundTransparency = 1;
		bodyLbl.Text = config.Message;
		bodyLbl.Font = theme.Font;
		bodyLbl.TextSize = 12.5;
